rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can read/write their own files
    match /doctor_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Anyone can read images (for profile display)
    match /doctor_images/{userId}/{allPaths=**} {
      allow read: if true;
    }
  }
}
